        "uiTheme": "vs",
        "path": "./themes/morning-lagoon-color-theme.json"
      }
    ]
  },
  "files": [
    "themes/*.json",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "url": "https://github.com/FabianBeiner/lagoon-colors.git",
    "type": "git"
  }
}

